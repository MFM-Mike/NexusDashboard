@using NexusDashboard.Shared.Models

<div class="small">
    <dl class="row mb-2">
        <dt class="col-2 text-muted">Timestamp</dt>
        <dd class="col-10">@Entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</dd>

        <dt class="col-2 text-muted">Level</dt>
        <dd class="col-10"><LevelBadge Level="Entry.Level" /></dd>

        <dt class="col-2 text-muted">Logger</dt>
        <dd class="col-10 font-monospace">@Entry.Logger</dd>

        <dt class="col-2 text-muted">Thread</dt>
        <dd class="col-10">@Entry.Thread</dd>

        @if (!string.IsNullOrEmpty(Entry.Domain))
        {
            <dt class="col-2 text-muted">Domain</dt>
            <dd class="col-10">@Entry.Domain</dd>
        }

        @if (!string.IsNullOrEmpty(Entry.Username))
        {
            <dt class="col-2 text-muted">User</dt>
            <dd class="col-10">@Entry.Username</dd>
        }

        <dt class="col-2 text-muted">Message</dt>
        <dd class="col-10">@Entry.Message</dd>
    </dl>

    @if (!string.IsNullOrEmpty(Entry.Exception))
    {
        <div class="mb-2">
            <div class="fw-semibold text-danger mb-1"><i class="bi bi-bug me-1"></i>Exception</div>
            <pre class="bg-dark text-light rounded p-3 small" style="white-space:pre-wrap;max-height:300px;overflow-y:auto;font-size:0.75rem">@Entry.Exception</pre>
        </div>
    }

    @if (Entry.Properties.Any())
    {
        <div>
            <div class="fw-semibold mb-1">Properties</div>
            <dl class="row mb-0">
                @foreach (var kv in Entry.Properties)
                {
                    <dt class="col-3 text-muted text-truncate" title="@kv.Key">@kv.Key</dt>
                    <dd class="col-9">@kv.Value</dd>
                }
            </dl>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public LogEntry Entry { get; set; } = null!;
}
