@page "/errors"
@rendermode InteractiveServer
@using NexusDashboard.Client.Services
@using NexusDashboard.Shared.Models
@inject DashboardStateService State

<PageTitle>Errors &amp; Fatals — NexusDashboard</PageTitle>

<h4 class="fw-bold mb-4">Errors &amp; Fatals</h4>

@if (State.ActiveFile == null)
{
    <div class="alert alert-info">Load a log file from the Overview page first.</div>
}
else
{
    var errors = State.ActiveFile.Entries
        .Where(e => e.Level is LogLevel.ERROR or LogLevel.FATAL)
        .OrderByDescending(e => e.Timestamp)
        .ToList();

    var withEx    = errors.Where(e => !string.IsNullOrEmpty(e.Exception)).ToList();
    var withoutEx = errors.Where(e => string.IsNullOrEmpty(e.Exception)).ToList();

    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <KpiCard Title="Total Errors" Value="@State.ActiveFile.Summary.ErrorCount.ToString("N0")"
                     Icon="bi-x-circle-fill" AccentColor="#dc3545" />
        </div>
        <div class="col-sm-4">
            <KpiCard Title="Fatal Events" Value="@State.ActiveFile.Summary.FatalCount.ToString("N0")"
                     Icon="bi-radioactive" AccentColor="#6f42c1" />
        </div>
        <div class="col-sm-4">
            <KpiCard Title="With Stack Trace" Value="@withEx.Count.ToString("N0")"
                     Icon="bi-bug-fill" AccentColor="#fd7e14" />
        </div>
    </div>

    <!-- Group by message pattern -->
    @{
        var grouped = errors
            .GroupBy(e => TruncateMessage(e.Message))
            .OrderByDescending(g => g.Count())
            .Take(20)
            .ToList();
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold border-0">
            <i class="bi bi-collection me-2 text-danger"></i>Top Error Patterns
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Message Pattern</th>
                        <th style="width:80px">Count</th>
                        <th style="width:120px">Last Seen</th>
                        <th style="width:80px">Level</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grp in grouped)
                    {
                        var last = grp.OrderByDescending(e => e.Timestamp).First();
                        <tr @onclick="() => ToggleGroup(grp.Key)" style="cursor:pointer">
                            <td class="small">@grp.Key</td>
                            <td><span class="badge bg-danger">@grp.Count()</span></td>
                            <td class="small text-muted">@last.Timestamp.ToString("g")</td>
                            <td><LevelBadge Level="last.Level" /></td>
                        </tr>
                        @if (_expandedGroup == grp.Key)
                        {
                            @foreach (var entry in grp.OrderByDescending(e => e.Timestamp).Take(5))
                            {
                                <tr class="bg-light">
                                    <td colspan="4" class="ps-4 py-2">
                                        <LogEntryDetail Entry="entry" />
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- All errors timeline -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold border-0">
            <i class="bi bi-clock-history me-2 text-danger"></i>All Errors (most recent first)
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:160px">Timestamp</th>
                        <th style="width:70px">Level</th>
                        <th style="width:200px">Logger</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in errors.Take(200))
                    {
                        <tr @onclick="() => ToggleEntry(entry.Id)" style="cursor:pointer">
                            <td class="small text-muted">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td><LevelBadge Level="entry.Level" /></td>
                            <td class="small text-truncate" style="max-width:200px">@entry.Logger</td>
                            <td class="small text-truncate" style="max-width:450px">
                                @if (entry.Exception != null) { <i class="bi bi-bug text-danger me-1"></i> }
                                @entry.Message
                            </td>
                        </tr>
                        @if (_expandedEntry == entry.Id)
                        {
                            <tr>
                                <td colspan="4" class="bg-light p-3">
                                    <LogEntryDetail Entry="entry" />
                                </td>
                            </tr>
                        }
                    }
                    @if (errors.Count > 200)
                    {
                        <tr><td colspan="4" class="text-center text-muted small py-2">Showing 200 of @errors.Count. Use Log Entries page for full filtered view.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private string? _expandedGroup;
    private int? _expandedEntry;

    protected override void OnInitialized() => State.OnStateChanged += StateHasChanged;
    public void Dispose() => State.OnStateChanged -= StateHasChanged;

    private void ToggleGroup(string key) => _expandedGroup = _expandedGroup == key ? null : key;
    private void ToggleEntry(int id) => _expandedEntry = _expandedEntry == id ? null : id;

    private static string TruncateMessage(string msg) =>
        msg.Length > 100 ? msg[..100] + "…" : msg;
}
