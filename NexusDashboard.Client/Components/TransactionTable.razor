@if (Transactions is not null)
{
    <div class="table-card">
        <div class="chart-header">
            <h3 class="chart-title">Recent Transactions</h3>
            <button class="btn-ghost">View all →</button>
        </div>
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Transactions)
                    {
                        <tr>
                            <td class="tx-id">@tx.Id</td>
                            <td>@tx.Customer</td>
                            <td class="tx-product">@tx.Product</td>
                            <td class="tx-amount">$@tx.Amount.ToString("N2")</td>
                            <td class="tx-date">@tx.Date.ToString("MMM d, h:mm tt")</td>
                            <td><span class="status-badge status-@tx.Status.ToLower()">@tx.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public List<Transaction>? Transactions { get; set; }
}
